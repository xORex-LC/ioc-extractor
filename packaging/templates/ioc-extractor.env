# ioc-extractor daemon — environment file (read by systemd EnvironmentFile=).
#
# Format: KEY=VALUE, one per line. systemd strips matching quotes but does not
# perform shell expansion. $JAVA_OPTS is split by systemd into separate ExecStart
# arguments.

# JVM options. Tune heap to the host; ExitOnOutOfMemoryError lets systemd restart
# on OOM instead of leaving a wedged JVM. Timezone/encoding are pinned for
# reproducible ECS timestamps and correct handling of cp1251 Word exports.
JAVA_OPTS=-Xms128m -Xmx512m -XX:+ExitOnOutOfMemoryError -Duser.timezone=UTC -Dfile.encoding=UTF-8

# SMB credentials referenced by ${SMB_USER}/${SMB_PASSWORD} in application.yml.
# Uncomment only when ioc.sync is enabled. Quote values containing whitespace or
# systemd.env syntax characters; the quotes are not passed to Spring.
#SMB_USER=ioc-sync
#SMB_PASSWORD="replace-me"
