# ioc-extractor daemon — environment file (read by systemd EnvironmentFile=).
#
# Format: KEY=VALUE, one per line, NO surrounding quotes (systemd takes the value
# literally; quotes would become part of the value). $JAVA_OPTS is word-split by
# systemd into separate ExecStart arguments.

# JVM options. Tune heap to the host; ExitOnOutOfMemoryError lets systemd restart
# on OOM instead of leaving a wedged JVM. Timezone/encoding are pinned for
# reproducible ECS timestamps and correct handling of cp1251 Word exports.
JAVA_OPTS=-Xms128m -Xmx512m -XX:+ExitOnOutOfMemoryError -Duser.timezone=UTC -Dfile.encoding=UTF-8
