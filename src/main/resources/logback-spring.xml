<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <springProperty scope="context" name="LOG_PATH" source="logging.file.path" defaultValue="var/logs"/>

    <springProfile name="!daemon">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="daemon">
        <appender name="ECS_JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/ioc-extractor.ecs.json</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/ioc-extractor.%d{yyyy-MM-dd}.%i.ecs.json.gz</fileNamePattern>
                <maxFileSize>10MB</maxFileSize>
                <maxHistory>14</maxHistory>
                <totalSizeCap>512MB</totalSizeCap>
            </rollingPolicy>
            <encoder class="co.elastic.logging.logback.EcsEncoder">
                <serviceName>ioc-extractor</serviceName>
                <serviceVersion>0.1.0-SNAPSHOT</serviceVersion>
                <eventDataset>ioc-extractor</eventDataset>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ECS_JSON_FILE"/>
        </root>
    </springProfile>
</configuration>
